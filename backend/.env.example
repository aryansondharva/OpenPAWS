# ─────────────────────────────────────────────
#  OpenPAWS — News Opportunism Engine
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# REQUIRED ─ Anthropic Claude (AI brain)
# Get free credits at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─────────────────────────────────────────────
# FREE NEWS APIs (all optional but recommended)
# The more you add, the better the story coverage
# ─────────────────────────────────────────────

# GNews API ─ Best for breaking news (100 req/day free)
# Sign up at: https://gnews.io
GNEWS_API_KEY=your-gnews-key-here

# Currents API ─ Best for environment/policy (600 req/day free!)
# Sign up at: https://currentsapi.services
CURRENTS_API_KEY=your-currents-key-here

# NewsData.io ─ Best for welfare/investigation stories (200 req/day free)
# Sign up at: https://newsdata.io
NEWSDATA_API_KEY=your-newsdata-key-here

# NewsAPI ─ General news (100 req/day free)
# Sign up at: https://newsapi.org
NEWSAPI_KEY=your-newsapi-key-here

# ─────────────────────────────────────────────
# SERVER CONFIG
# ─────────────────────────────────────────────
PORT=3001
CACHE_MINUTES=15
