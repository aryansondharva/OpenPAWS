{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "dist",
  "installCommand": "cd api && npm install && cd ../backend && npm install && cd ../frontend && npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.js" }
  ],
  "functions": {
    "api/server.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "backend/services/**"
    }
  },
  "env": {
    "GEMINI_API_KEY": "@gemini-api-key",
    "GNEWS_API_KEY": "@gnews-api-key",
    "CURRENTS_API_KEY": "@currents-api-key",
    "NEWSDATA_API_KEY": "@newsdata-api-key",
    "NEWSAPI_KEY": "@newsapi-key"
  }
}
