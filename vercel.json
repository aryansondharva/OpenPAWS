{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api",
      "dest": "/api"
    }
  ],
  "env": {
    "GEMINI_API_KEY": "@gemini-api-key",
    "NEWS_API_KEY": "@news-api-key"
  },
  "functions": {
    "api/server.js": {
      "maxDuration": 30
    }
  },
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite"
}
